<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or site.title }} — Sofia Panting</title>
{%- set pageDescription = excerpt or description or site.hero.subtitle %}
{%- set pageImage = meta.url + "/images/og-default.png" %}
{%- if image %}{% set pageImage = image if image.startsWith("http") else meta.url + image %}{% endif %}
<meta name="description" content="{{ pageDescription }}">
<meta name="author" content="{{ meta.author }}">
<meta name="theme-color" content="#FAF6F1">
<link rel="canonical" href="{{ meta.url }}{{ page.url }}">
<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:type" content="{% if '/posts/' in page.url %}article{% else %}website{% endif %}">
<meta property="og:title" content="{{ title or site.title }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:url" content="{{ meta.url }}{{ page.url }}">
<meta property="og:image" content="{{ pageImage }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title or site.title }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ pageImage }}">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">
<link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ meta.url }}/feed.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
{%- if '/posts/' in page.url %}
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BlogPosting","headline":{{ title | dump | safe }},"description":{{ pageDescription | dump | safe }},"image":{{ pageImage | dump | safe }},"datePublished":"{{ page.date | isoDate }}","url":"{{ meta.url }}{{ page.url }}","author":{"@type":"Person","name":"{{ meta.author }}"}}</script>
{%- elif page.url == '/' %}
<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","name":"{{ site.title }}","url":"{{ meta.url }}/","description":{{ pageDescription | dump | safe }}}</script>
{%- endif %}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --cream:#FAF6F1;
  --parchment:#F2EBE0;
  --blush:#EDD5C5;
  --rose:#C8856A;
  --deep-rose:#9B5E48;
  --burgundy:#6B3228;
  --sage:#A8B89A;
  --warm-dark:#2A1F1A;
  --muted:#8A7468;
  --light-muted:#BBA99E;
  --border:rgba(139,104,88,0.13);
  --serif:'Playfair Display',Georgia,serif;
  --sans:'Jost',sans-serif;
}

html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--warm-dark);font-family:var(--sans);font-size:15px;line-height:1.75;overflow-x:hidden}

/* grain */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");pointer-events:none;z-index:9000;opacity:0.42}

/* TICKER */
.ticker{background:var(--warm-dark);color:var(--blush);font-size:11px;letter-spacing:.18em;text-transform:uppercase;padding:9px 0;overflow:hidden;white-space:nowrap;font-family:var(--sans)}
.ticker-inner{display:inline-block;animation:tick 32s linear infinite}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.tsep{margin:0 1.6rem;opacity:.28}

/* NAV */
nav{background:rgba(250,246,241,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 1.5rem;position:sticky;top:0;z-index:500;display:flex;align-items:center;justify-content:space-between;height:62px;gap:1rem}
.nav-logo{font-family:var(--serif);font-size:1.35rem;font-weight:400;color:var(--warm-dark);text-decoration:none;flex-shrink:0}
.nav-logo em{font-style:italic;color:var(--rose)}
.nav-links{display:flex;gap:1.6rem;list-style:none}
.nav-links a{text-decoration:none;color:var(--muted);font-size:11px;letter-spacing:.11em;text-transform:uppercase;font-weight:400;position:relative;transition:color .2s;white-space:nowrap}
.nav-links a::after{content:'';position:absolute;left:0;bottom:-3px;width:0;height:1px;background:var(--rose);transition:width .25s}
.nav-links a:hover{color:var(--warm-dark)}
.nav-links a:hover::after{width:100%}
.nav-socials{display:flex;gap:.6rem;flex-shrink:0}
.nav-social{display:flex;align-items:center;gap:6px;text-decoration:none;color:var(--muted);font-size:11px;letter-spacing:.05em;padding:6px 11px;border:1px solid var(--border);border-radius:20px;transition:all .2s;font-family:var(--sans);white-space:nowrap}
.nav-social:hover{color:var(--rose);border-color:var(--rose);background:rgba(200,133,106,.05)}
.nav-social svg{width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.nav-toggle{display:none;flex-direction:column;justify-content:center;align-items:flex-end;gap:5px;width:28px;height:28px;background:none;border:none;cursor:pointer;padding:0;flex-shrink:0}
.nav-toggle span{display:block;width:100%;height:1.5px;background:var(--warm-dark);transition:transform .25s,opacity .2s,width .25s}
.nav-toggle.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg);width:100%}
.nav-toggle.open span:nth-child(2){opacity:0}
.nav-toggle.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg);width:100%}
@media(max-width:768px){
  .nav-toggle{display:flex}
  .nav-links{
    display:flex;flex-direction:column;gap:0;
    position:fixed;top:62px;left:0;right:0;
    background:var(--cream);border-bottom:1px solid var(--border);
    box-shadow:0 16px 30px rgba(42,31,26,.1);
    padding:0;max-height:0;overflow:hidden;opacity:0;pointer-events:none;
    transition:max-height .3s ease,opacity .2s ease;z-index:499;
  }
  .nav-links.open{max-height:400px;opacity:1;pointer-events:auto;padding:.5rem 0}
  .nav-links li{width:100%}
  .nav-links a{display:block;padding:.9rem 1.5rem;font-size:12px}
  .nav-links a::after{display:none}
  .nav-logo{font-size:1.15rem}
}
@media(max-width:480px){
  .nav-social-text{display:none}
  .nav-social{padding:8px;border-radius:50%}
  .nav-social svg{width:15px;height:15px}
}

/* HERO */
.hero{min-height:560px;display:grid;grid-template-columns:1fr 1fr;position:relative;overflow:hidden}
@media(max-width:768px){
  .hero{grid-template-columns:1fr;min-height:auto}
}

.hero-left{display:flex;flex-direction:column;justify-content:center;padding:5rem 3.5rem 5rem 4rem;position:relative;z-index:2}
@media(max-width:768px){
  .hero-left{padding:3.5rem 1.5rem 2rem}
}

.hero-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:1.6rem;opacity:0;animation:fadeUp .8s .15s ease forwards}
.eyebrow-line{width:26px;height:1px;background:var(--rose);flex-shrink:0}
.eyebrow-text{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--rose);font-weight:500}
.hero-title{font-family:var(--serif);font-size:clamp(2.6rem,4.5vw,5rem);font-weight:400;line-height:1.1;margin-bottom:1.3rem;opacity:0;animation:fadeUp .9s .3s ease forwards}
.hero-title em{font-style:italic;color:var(--rose);display:block}
.hero-sub{color:var(--muted);font-size:14px;max-width:390px;margin-bottom:2rem;font-weight:300;line-height:1.85;opacity:0;animation:fadeUp .9s .45s ease forwards}
.hero-btns{display:flex;align-items:center;gap:1.2rem;flex-wrap:wrap;opacity:0;animation:fadeUp .9s .6s ease forwards}

.btn-primary{background:var(--warm-dark);color:var(--cream);padding:12px 24px;border-radius:2px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:500;font-family:var(--sans);border:none;cursor:pointer;text-decoration:none;display:inline-block;transition:background .22s,transform .15s}
.btn-primary:hover{background:var(--burgundy);transform:translateY(-1px)}
.btn-ghost{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:5px;transition:color .2s,gap .2s}
.btn-ghost:hover{color:var(--warm-dark);gap:9px}

/* HERO RIGHT */
.hero-right{position:relative;background:var(--parchment);display:flex;align-items:center;justify-content:center;overflow:hidden;min-height:420px}
@media(max-width:768px){
  .hero-right{min-height:340px}
}

.hero-orb{width:320px;height:320px;border-radius:50%;background:var(--blush);position:absolute;opacity:.55;animation:float 9s ease-in-out infinite}
.hero-orb-2{width:200px;height:200px;border-radius:50%;background:var(--sage);opacity:.22;position:absolute;top:8%;right:8%;animation:float 12s 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0) rotate(0)}50%{transform:translateY(-16px) rotate(4deg)}}

.hero-photo{position:relative;z-index:2;width:220px;height:280px;border-radius:3px;overflow:hidden;box-shadow:0 28px 70px rgba(42,31,26,.16);animation:fadeIn 1s .65s ease both;flex-shrink:0}
.hero-photo img{width:100%;height:100%;object-fit:cover;display:block}
.photo-placeholder{width:100%;height:100%;background:linear-gradient(160deg,#EDD5C5 0%,#C8856A 50%,#9B5E48 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem}
.photo-placeholder span{font-size:3.5rem}
.photo-placeholder p{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:rgba(250,246,241,.7);font-weight:500}

.hero-card{position:absolute;bottom:10%;right:4%;z-index:3;background:rgba(250,246,241,.94);backdrop-filter:blur(10px);border:1px solid rgba(200,133,106,.18);border-radius:3px;padding:1.4rem 1.5rem;max-width:220px;box-shadow:0 20px 50px rgba(42,31,26,.12);animation:fadeIn 1s 1s ease both}
.hc-label{font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--rose);margin-bottom:.7rem;font-weight:500;display:flex;align-items:center;gap:6px}
.hc-dot{width:5px;height:5px;background:var(--rose);border-radius:50%;animation:blink 2.2s ease-in-out infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
.hc-title{font-family:var(--serif);font-size:.95rem;font-weight:400;line-height:1.35;color:var(--warm-dark);margin-bottom:.7rem}
.hc-meta{display:flex;justify-content:space-between;font-size:10px;color:var(--light-muted);border-top:1px solid var(--border);padding-top:.6rem}

.formula-badge{position:absolute;bottom:12%;left:5%;background:var(--warm-dark);color:var(--blush);padding:9px 14px;border-radius:2px;font-size:11px;font-family:'Courier New',monospace;letter-spacing:.04em;z-index:3;animation:fadeIn 1s 1.2s ease both;line-height:1.65;box-shadow:0 8px 24px rgba(42,31,26,.2)}
.formula-badge span{color:var(--sage);opacity:.65;font-size:9.5px;display:block;margin-top:2px}

.scroll-hint{position:absolute;bottom:1.8rem;left:3.5rem;display:flex;flex-direction:column;align-items:center;gap:7px;z-index:3;opacity:0;animation:fadeIn 1s 1.5s ease forwards}
@media(max-width:768px){.scroll-hint{display:none}}
.scroll-hint span{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--light-muted)}
.scroll-line{width:1px;height:34px;background:linear-gradient(to bottom,var(--rose),transparent);animation:scrollAnim 2s ease-in-out infinite}
@keyframes scrollAnim{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* ABOUT BANNER */
.about-banner{background:var(--parchment);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:3.5rem 4rem;display:grid;grid-template-columns:auto 1fr;gap:3rem;align-items:center;position:relative;overflow:hidden}
@media(max-width:768px){
  .about-banner{grid-template-columns:1fr;gap:1.8rem;padding:2.5rem 1.5rem;text-align:center}
  .avatar-wrap{margin:0 auto}
}
.about-banner::before{content:'"';font-family:var(--serif);font-size:16rem;color:var(--rose);opacity:.04;position:absolute;top:-1.5rem;left:3rem;line-height:1;pointer-events:none}
.avatar-wrap{position:relative;flex-shrink:0}
.avatar{width:100px;height:100px;border-radius:50%;overflow:hidden;border:2.5px solid var(--rose);position:relative;z-index:1}
.avatar img{width:100%;height:100%;object-fit:cover;display:block}
.avatar-placeholder{width:100%;height:100%;background:linear-gradient(135deg,var(--blush),var(--rose));display:flex;align-items:center;justify-content:center;font-size:2.5rem}
.avatar-ring{width:120px;height:120px;border-radius:50%;border:1px dashed rgba(200,133,106,.32);position:absolute;top:-10px;left:-10px;animation:spin 20s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.about-name{font-family:var(--serif);font-size:1.5rem;font-weight:400;margin-bottom:.2rem}
.about-name em{font-style:italic;color:var(--rose)}
.about-role{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;font-weight:400}
.about-quote{font-family:var(--serif);font-size:1.05rem;font-weight:300;font-style:italic;line-height:1.85;max-width:600px;color:var(--warm-dark)}
.about-quote strong{font-style:normal;font-weight:500;color:var(--rose);text-decoration:underline;text-decoration-color:rgba(200,133,106,.28);text-underline-offset:3px}

/* FLAGS + BADGES */
.about-badges{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1rem}
@media(max-width:768px){.about-badges{justify-content:center}}
.badge{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border:1px solid var(--border);border-radius:20px;font-size:11px;color:var(--muted);background:transparent;font-family:var(--sans)}

/* SECTION WRAP */
.section-wrap{padding:3rem 2.5rem 0;max-width:1140px;margin:0 auto}
@media(max-width:768px){.section-wrap{padding:2.5rem 1.2rem 0}}
.posts-wrap{padding:2rem 2.5rem 5rem;max-width:1140px;margin:0 auto}
@media(max-width:768px){.posts-wrap{padding:2rem 1.2rem 4rem}}
.section-hdr{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:2rem}
.section-hdr h1,.section-hdr h2{font-family:var(--serif);font-size:1.85rem;font-weight:400}
.section-hdr h1 em,.section-hdr h2 em{font-style:italic;color:var(--rose)}
.section-hdr a{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--rose);text-decoration:none;display:flex;align-items:center;gap:4px;transition:gap .2s;white-space:nowrap}
.section-hdr a:hover{gap:9px}

/* TOPICS */
.topics-row{display:flex;gap:.65rem;flex-wrap:wrap}
.topic-pill{padding:8px 16px;border:1px solid var(--border);border-radius:40px;font-size:11.5px;letter-spacing:.04em;color:var(--muted);cursor:pointer;transition:all .22s;display:flex;align-items:center;gap:5px;background:transparent;font-family:var(--sans)}
.topic-pill:hover{background:var(--warm-dark);border-color:var(--warm-dark);color:var(--cream);transform:translateY(-2px)}
.topic-pill.active{background:var(--rose);border-color:var(--rose);color:var(--cream)}

/* POSTS GRID */
.posts-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.8rem}
@media(max-width:900px){.posts-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.posts-grid{grid-template-columns:1fr}}
.post-card{cursor:pointer;text-decoration:none;color:inherit;display:block}
.card-img{width:100%;aspect-ratio:4/3;border-radius:3px;margin-bottom:1rem;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;transition:transform .4s}
.post-card:hover .card-img{transform:scale(1.025)}
.card-photo{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
.card-emoji{font-size:3rem;position:relative;z-index:1}
.card-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(42,31,26,.28) 0%,transparent 55%);opacity:0;transition:opacity .3s;z-index:2}
.post-card:hover .card-overlay{opacity:1}
.ia{background:linear-gradient(135deg,#EDD5C5,#E2BEA8)}
.ib{background:linear-gradient(135deg,#C4D8B8,#B0C9A0)}
.ic{background:linear-gradient(135deg,#D5C8DE,#C2B0CC)}
.id{background:linear-gradient(135deg,#EEE0C2,#E4CCAA)}
.ie{background:linear-gradient(135deg,#C4D8DC,#AEC4CC)}
.if{background:linear-gradient(135deg,#DADACC,#C6C4B2)}
.post-cat{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:.4rem}
.post-title{font-family:var(--serif);font-size:1.05rem;font-weight:400;line-height:1.35;margin-bottom:.4rem;transition:color .2s}
.post-card:hover .post-title{color:var(--deep-rose)}
.post-excerpt{font-size:13px;color:var(--muted);line-height:1.72;margin-bottom:.85rem;font-weight:300}
.post-foot{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--light-muted);border-top:1px solid var(--border);padding-top:.75rem}
.post-read{color:var(--rose);text-decoration:none;font-size:11px;letter-spacing:.1em;text-transform:uppercase;font-weight:500;display:flex;align-items:center;gap:4px;transition:gap .2s}
.post-read:hover{gap:8px}

/* FEATURED DARK */
.feat-dark{background:var(--warm-dark);padding:4.5rem 4rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;position:relative;overflow:hidden}
@media(max-width:768px){
  .feat-dark{grid-template-columns:1fr;padding:3rem 1.5rem;gap:2.5rem}
}
.feat-dark::before{content:'';position:absolute;top:-80px;right:-80px;width:280px;height:280px;border-radius:50%;background:var(--rose);opacity:.055;pointer-events:none}
.feat-dark::after{content:'';position:absolute;bottom:-50px;left:38%;width:180px;height:180px;border-radius:50%;background:var(--sage);opacity:.055;pointer-events:none}
.fd-label{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:1.1rem;display:flex;align-items:center;gap:9px}
.fd-label::before{content:'';width:16px;height:1px;background:var(--rose)}
.fd-title{font-family:var(--serif);font-size:clamp(1.8rem,2.8vw,2.7rem);font-weight:400;line-height:1.2;color:var(--cream);margin-bottom:1rem}
.fd-title em{font-style:italic;color:var(--rose)}
.fd-body{font-size:13.5px;color:rgba(250,246,241,.52);line-height:1.9;margin-bottom:1.6rem;font-weight:300}
.ing-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem}
.ing-tile{border:1px solid rgba(250,246,241,.07);border-radius:3px;padding:1.2rem 1rem;position:relative;transition:border-color .25s,background .25s}
.ing-tile:hover{border-color:rgba(200,133,106,.28);background:rgba(200,133,106,.06)}
.it-icon{font-size:1.6rem;margin-bottom:.55rem;display:block}
.it-tag{position:absolute;top:9px;right:9px;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--rose);opacity:.65}
.it-name{font-family:var(--serif);font-size:.88rem;color:var(--cream);margin-bottom:.3rem}
.it-desc{font-size:11px;color:rgba(250,246,241,.4);line-height:1.5}

/* SOFIA'S STORY / PROFILE SECTION */
.profile-section{padding:4rem 2.5rem;max-width:1140px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:4rem;align-items:start}
@media(max-width:768px){
  .profile-section{grid-template-columns:1fr;gap:2.5rem;padding:3rem 1.2rem}
}
.profile-photo-wrap{position:relative}
.profile-photo{width:100%;aspect-ratio:3/4;border-radius:3px;overflow:hidden;position:relative}
.profile-photo img{width:100%;height:100%;object-fit:cover;display:block}
.profile-photo-placeholder{width:100%;height:100%;background:linear-gradient(160deg,#EDD5C5 0%,#C8856A 55%,#9B5E48 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.8rem}
.profile-photo-placeholder span{font-size:5rem}
.profile-photo-placeholder p{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:rgba(250,246,241,.75);font-weight:500;text-align:center;padding:0 1rem}
.profile-accent{position:absolute;top:-12px;left:-12px;width:80px;height:80px;border:1px solid rgba(200,133,106,.3);border-radius:2px;z-index:-1}
.profile-accent-2{position:absolute;bottom:-12px;right:-12px;width:60px;height:60px;border:1px solid rgba(200,133,106,.2);border-radius:2px;z-index:-1}
.profile-eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:1rem;display:flex;align-items:center;gap:9px}
.profile-eyebrow::before{content:'';width:18px;height:1px;background:var(--rose)}
.profile-title{font-family:var(--serif);font-size:2rem;font-weight:400;line-height:1.2;margin-bottom:1.3rem}
.profile-title em{font-style:italic;color:var(--rose)}
.profile-text{font-size:14px;color:var(--muted);line-height:1.9;margin-bottom:1rem;font-weight:300}
.profile-text strong{color:var(--warm-dark);font-weight:500}
.profile-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1.8rem 0;padding:1.5rem;background:var(--parchment);border-radius:3px;border:1px solid var(--border)}
.stat-num{font-family:var(--serif);font-size:1.8rem;font-weight:400;color:var(--rose);margin-bottom:.2rem}
.stat-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;line-height:1.4}
.profile-links{display:flex;gap:.7rem;flex-wrap:wrap;margin-top:1.5rem}
.profile-link{display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border:1px solid var(--border);border-radius:2px;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:all .22s;font-family:var(--sans);font-weight:400}
.profile-link:hover{background:var(--warm-dark);border-color:var(--warm-dark);color:var(--cream)}
.profile-link svg{width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.linkedin-link{background:rgba(10,102,194,.07);border-color:rgba(10,102,194,.25);color:rgba(10,102,194,.9)}
.linkedin-link:hover{background:#0A66C2;border-color:#0A66C2;color:white}
.linkedin-link svg{stroke:currentColor}

/* IG STRIP */
.ig-wrap{padding:3.5rem 2.5rem;max-width:1140px;margin:0 auto}
@media(max-width:768px){.ig-wrap{padding:2.5rem 1.2rem}}
.ig-hdr{display:flex;align-items:center;gap:10px;margin-bottom:1.4rem;flex-wrap:wrap}
.ig-icon{width:32px;height:32px;background:linear-gradient(135deg,#F5A623 0%,#E91E8C 50%,#9B59B6 100%);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ig-icon svg{width:16px;height:16px;stroke:white;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}
.ig-handle{font-family:var(--serif);font-size:1rem;font-weight:400}
.ig-handle em{font-style:italic;color:var(--rose)}
.ig-handle small{font-family:var(--sans);font-size:11px;color:var(--muted);font-weight:300;margin-left:4px}
.ig-follow{margin-left:auto;font-size:11px;letter-spacing:.11em;text-transform:uppercase;color:var(--rose);text-decoration:none;display:flex;align-items:center;gap:4px;transition:gap .2s}
.ig-follow:hover{gap:8px}
.ig-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:4px;border-radius:3px;overflow:hidden}
@media(max-width:560px){.ig-grid{grid-template-columns:repeat(3,1fr)}}
.ig-tile{aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:1.8rem;position:relative;overflow:hidden;cursor:pointer}
.ig-tile img{width:100%;height:100%;object-fit:cover;display:block}
.ig-tile-ov{position:absolute;inset:0;background:rgba(42,31,26,.58);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .25s}
.ig-tile:hover .ig-tile-ov{opacity:1}
.ig-tile-ov svg{width:18px;stroke:white;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}

/* NEWSLETTER */
.nl-section{background:var(--parchment);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:5rem 1.5rem;text-align:center;position:relative;overflow:hidden}
.nl-section::before{content:'✦';font-family:var(--serif);font-size:15rem;color:var(--rose);opacity:.04;position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);pointer-events:none;line-height:1}
.nl-eyebrow{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:1rem}
.nl-title{font-family:var(--serif);font-size:clamp(1.8rem,3.5vw,2.9rem);font-weight:400;margin-bottom:.65rem;line-height:1.18}
.nl-title em{font-style:italic;color:var(--rose)}
.nl-sub{color:var(--muted);font-size:13.5px;max-width:360px;margin:0 auto 1.8rem;font-weight:300;line-height:1.82}
.nl-form{display:flex;max-width:400px;margin:0 auto;position:relative;z-index:1}
@media(max-width:480px){.nl-form{flex-direction:column;gap:.7rem}}
.nl-form input{flex:1;padding:13px 18px;border:1px solid rgba(139,104,88,.28);background:var(--cream);font-family:var(--sans);font-size:13.5px;color:var(--warm-dark);outline:none;border-radius:2px 0 0 2px;transition:border-color .2s}
@media(max-width:480px){.nl-form input{border-radius:2px}}
.nl-form input::placeholder{color:var(--light-muted)}
.nl-form input:focus{border-color:var(--rose)}
.nl-form button{background:var(--warm-dark);color:var(--cream);border:1px solid var(--warm-dark);padding:13px 20px;font-family:var(--sans);font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;border-radius:0 2px 2px 0;transition:background .2s;white-space:nowrap}
@media(max-width:480px){.nl-form button{border-radius:2px}}
.nl-form button:hover{background:var(--burgundy);border-color:var(--burgundy)}
.nl-note{font-size:11px;color:var(--light-muted);margin-top:.85rem;position:relative;z-index:1}
.nl-form input:disabled,.nl-form button:disabled{opacity:.45;cursor:not-allowed}
.nl-form button:disabled:hover{background:var(--warm-dark);border-color:var(--warm-dark)}
.nl-hp{position:absolute;left:-9999px;width:1px;height:1px;opacity:0}
.nl-success,.nl-error{display:none;font-size:13px;margin-top:.85rem;position:relative;z-index:1}
.nl-success{color:var(--deep-rose)}
.nl-error{color:var(--rose)}
.nl-success.show,.nl-error.show{display:block}

/* FOOTER */
footer{background:var(--warm-dark);color:rgba(250,246,241,.45);padding:3.5rem 3rem 2.5rem}
@media(max-width:768px){footer{padding:3rem 1.5rem 2rem}}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:2.5rem;margin-bottom:2.5rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(250,246,241,.07)}
@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr;gap:2rem}}
@media(max-width:400px){.footer-grid{grid-template-columns:1fr}}
.footer-brand{font-family:var(--serif);font-size:1.45rem;color:var(--cream);font-weight:400;margin-bottom:.5rem}
.footer-brand em{font-style:italic;color:var(--rose)}
.footer-desc{font-size:12.5px;line-height:1.75;font-weight:300;margin-bottom:1.3rem;max-width:200px}
.footer-socials{display:flex;flex-direction:column;gap:.5rem}
.footer-social{display:inline-flex;align-items:center;gap:7px;padding:7px 13px;border:1px solid rgba(250,246,241,.12);border-radius:2px;font-size:11px;letter-spacing:.09em;text-transform:uppercase;color:rgba(250,246,241,.5);text-decoration:none;transition:all .2s;font-family:var(--sans);width:fit-content}
.footer-social:hover{border-color:rgba(200,133,106,.4);color:var(--blush)}
.footer-social svg{width:12px;stroke:currentColor;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}
.footer-col-title{font-size:9.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(250,246,241,.28);margin-bottom:1rem;font-weight:500}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:.5rem}
.footer-links a{text-decoration:none;color:rgba(250,246,241,.4);font-size:13px;font-weight:300;transition:color .2s,padding-left .2s;display:block}
.footer-links a:hover{color:var(--cream);padding-left:5px}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;font-size:10.5px;color:rgba(250,246,241,.2);letter-spacing:.04em;flex-wrap:wrap;gap:.5rem}
.footer-sig{font-family:var(--serif);font-style:italic;font-size:.95rem;color:rgba(200,133,106,.38)}

/* UNSPLASH photo tints */
.tint-rose{filter:sepia(.3) hue-rotate(-10deg) saturate(1.1)}
.tint-sage{filter:sepia(.2) hue-rotate(60deg) saturate(.9)}

/* POST READING PAGE */
.post-hero{padding:3.5rem 2.5rem 2.5rem;max-width:760px;margin:0 auto}
@media(max-width:768px){.post-hero{padding:2.5rem 1.2rem 1.5rem}}
.post-back{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--rose);text-decoration:none;display:inline-flex;align-items:center;gap:5px;margin-bottom:1.6rem;transition:gap .2s}
.post-back:hover{gap:9px}
.post-hero-cat{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:.8rem}
.post-hero-title{font-family:var(--serif);font-size:clamp(1.9rem,4vw,2.8rem);font-weight:400;line-height:1.2;margin-bottom:1.2rem}
.post-hero-meta{display:flex;gap:1rem;font-size:12px;color:var(--light-muted);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:.9rem 0}
.post-hero-img{width:100%;max-width:760px;margin:0 auto 2.5rem;aspect-ratio:16/9;border-radius:3px;overflow:hidden;display:block}
.post-hero-img img{width:100%;height:100%;object-fit:cover;display:block}
.post-content{max-width:680px;margin:0 auto;padding:0 2.5rem 5rem;font-size:15.5px;line-height:1.9;color:var(--warm-dark)}
@media(max-width:768px){.post-content{padding:0 1.2rem 4rem}}
.post-content p{margin-bottom:1.3rem;font-weight:300}
.post-content h2{font-family:var(--serif);font-size:1.5rem;font-weight:400;margin:2.2rem 0 1rem}
.post-content h3{font-family:var(--serif);font-size:1.2rem;font-weight:400;margin:1.8rem 0 .8rem}
.post-content strong{font-weight:500;color:var(--deep-rose)}
.post-content em{font-style:italic}
.post-content a{color:var(--rose);text-decoration:underline;text-decoration-color:rgba(200,133,106,.35)}
.post-content blockquote{border-left:2px solid var(--rose);padding:.3rem 0 .3rem 1.4rem;margin:1.6rem 0;font-style:italic;color:var(--muted)}
.post-content ul,.post-content ol{margin:0 0 1.3rem 1.3rem}
.post-content li{margin-bottom:.5rem;font-weight:300}
.post-content img{width:100%;border-radius:3px;margin:1.6rem 0}
.post-content code{background:var(--parchment);padding:.15em .4em;border-radius:2px;font-size:.9em}

/* POST PREV/NEXT NAV */
.post-nav{max-width:760px;margin:0 auto;padding:0 2.5rem 3.5rem;display:grid;grid-template-columns:1fr 1fr;gap:1rem}
@media(max-width:768px){.post-nav{padding:0 1.2rem 2.5rem;grid-template-columns:1fr}}
.post-nav-link{border:1px solid var(--border);border-radius:3px;padding:1.2rem 1.4rem;text-decoration:none;display:block;transition:border-color .22s,background .22s}
.post-nav-link:hover{border-color:rgba(200,133,106,.4);background:rgba(200,133,106,.04)}
.post-nav-link.next{text-align:right}
.post-nav-label{font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:.4rem}
.post-nav-title{font-family:var(--serif);font-size:.98rem;color:var(--warm-dark);line-height:1.4}
.post-nav-spacer{visibility:hidden}
@media(max-width:768px){.post-nav-spacer{display:none}}

/* 404 */
.nf-wrap{min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 1.5rem}
.nf-code{font-family:var(--serif);font-style:italic;font-size:clamp(5rem,14vw,9rem);color:var(--rose);line-height:1;margin-bottom:1rem}
.nf-title{font-family:var(--serif);font-size:1.6rem;margin-bottom:.7rem}
.nf-sub{color:var(--muted);font-size:14px;font-weight:300;max-width:380px;margin-bottom:2rem;line-height:1.8}
</style>
</head>
<body>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-inner">
    {% for item in site.ticker %}<span>{{ item }}</span><span class="tsep">✦</span>{% endfor %}
    {% for item in site.ticker %}<span>{{ item }}</span><span class="tsep">✦</span>{% endfor %}
  </div>
</div>

<!-- NAV -->
<nav>
  <a href="/" class="nav-logo">Sofi<em>i</em>sticated</a>
  <ul class="nav-links">
    {% for link in site.nav_links %}<li><a href="{% if link == 'About' %}/#about{% else %}/blog/?category={{ link | urlencode }}{% endif %}">{{ link }}</a></li>{% endfor %}
  </ul>
  <div class="nav-socials">
    <a href="{{ site.social.instagram_url }}" target="_blank" class="nav-social">
      <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.01" stroke-width="3"/></svg>
      <span class="nav-social-text">{{ site.social.instagram_handle }}</span>
    </a>
    <a href="{{ site.social.linkedin_url }}" target="_blank" class="nav-social">
      <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      <span class="nav-social-text">LinkedIn</span>
    </a>
  </div>
  <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

{{ content | safe }}

<!-- FOOTER -->
<footer>
  <div class="footer-grid">
    <div>
      <div class="footer-brand">Sofi<em>i</em>sticated</div>
      <div class="footer-desc">{{ site.footer.description }}</div>
      <div class="footer-socials">
        <a href="{{ site.social.instagram_url }}" target="_blank" class="footer-social">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.01" stroke-width="3"/></svg>
          {{ site.social.instagram_handle }}
        </a>
        <a href="{{ site.social.linkedin_url }}" target="_blank" class="footer-social">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          Sofia Panting
        </a>
      </div>
    </div>
    <div>
      <div class="footer-col-title">Explore</div>
      <ul class="footer-links">
        <li><a href="/blog/">All posts</a></li>
        {% for link in site.nav_links %}<li><a href="{% if link == 'About' %}/#about{% else %}/blog/?category={{ link | urlencode }}{% endif %}">{{ link }}</a></li>{% endfor %}
      </ul>
    </div>
    <div>
      <div class="footer-col-title">Sofia</div>
      <ul class="footer-links">
        <li><a href="/#about">About me</a></li>
        <li><a href="/#profile">My story</a></li>
        <li><a href="mailto:{{ site.social.email }}">Contact</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-title">Connect</div>
      <ul class="footer-links">
        <li><a href="{{ site.social.instagram_url }}" target="_blank">Instagram</a></li>
        <li><a href="{{ site.social.linkedin_url }}" target="_blank">LinkedIn</a></li>
        <li><a href="mailto:{{ site.social.email }}">Email</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>{{ site.footer.copyright }}</span>
    <span class="footer-sig">Sofiisticated</span>
    <span>Made with chemistry ⚗️</span>
  </div>
</footer>

<script>
const els = document.querySelectorAll('.post-card,.ing-tile,.topic-pill,.ig-tile,.profile-photo-wrap,.profile-content,.stat-num');
const io = new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){
      e.target.style.animationDelay=(i*.07)+'s';
      e.target.style.animation='fadeUp .65s ease both';
      io.unobserve(e.target);
    }
  });
},{threshold:.08});
els.forEach(el=>{el.style.opacity='0';io.observe(el);});

const navToggle = document.getElementById('navToggle');
const navLinks = document.querySelector('.nav-links');
if(navToggle && navLinks){
  navToggle.addEventListener('click',()=>{
    const isOpen = navLinks.classList.toggle('open');
    navToggle.classList.toggle('open',isOpen);
    navToggle.setAttribute('aria-expanded',isOpen);
  });
  navLinks.querySelectorAll('a').forEach(a=>{
    a.addEventListener('click',()=>{
      navLinks.classList.remove('open');
      navToggle.classList.remove('open');
      navToggle.setAttribute('aria-expanded','false');
    });
  });
}

const newsletterForm = document.getElementById('newsletterForm');
if(newsletterForm){
  newsletterForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const successEl = document.getElementById('newsletterSuccess');
    const errorEl = document.getElementById('newsletterError');
    errorEl.classList.remove('show');
    const data = new FormData(newsletterForm);
    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(data).toString(),
    })
      .then(() => {
        newsletterForm.reset();
        newsletterForm.style.display = 'none';
        successEl.classList.add('show');
      })
      .catch(() => {
        errorEl.classList.add('show');
      });
  });
}

document.querySelectorAll('.topic-pill').forEach(p=>{
  p.addEventListener('click',()=>{
    document.querySelectorAll('.topic-pill').forEach(x=>x.classList.remove('active'));
    p.classList.add('active');
    const cat = p.dataset.category;
    document.querySelectorAll('.post-card').forEach(card=>{
      card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
    });
  });
});

const catParam = new URLSearchParams(location.search).get('category');
if(catParam){
  const pill = Array.from(document.querySelectorAll('.topic-pill')).find(
    p => p.dataset.category && p.dataset.category.toLowerCase() === catParam.toLowerCase()
  );
  if(pill) pill.click();
}
</script>
</body>
</html>
